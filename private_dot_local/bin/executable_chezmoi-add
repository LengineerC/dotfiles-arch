#!/bin/bash

BASE_DIR="$HOME"

sources=(
  ".zshrc"
  ".config/DankMaterialShell"
  ".config/niri"
  ".local/share/fcitx5/pinyin/dictionaries"
  ".config/quickshell/dms"
  "Applications/easyeffects"
  "Scripts"
  ".config/kitty"
  ".config/fastfetch"
  ".config/nvim"
  ".local/bin/chezmoi-add"
  ".local/bin/chezmoi-push"
  ".local/bin/kvm-passthrough"
)

for src in "${sources[@]}"; do
  chezmoi add "$BASE_DIR/$src"
done

echo "Add finished."
