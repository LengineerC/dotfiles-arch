window-rule {
    match app-id=r#"wps$"#
    match app-id="XnView"
    match app-id="com.danklinux.dms"

    open-floating true
}

window-rule {
    match app-id="com.danklinux.dms" title="系统监视器"
    open-floating true
}

window-rule {
    match app-id="neovide"
    match app-id="code"
    match app-id="firefox"
    match app-id="google-chrome"
    
    open-maximized true
}
